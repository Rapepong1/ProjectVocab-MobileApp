<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:padding="12dp">

    <TextView
        android:id="@+id/widget_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Daily Vocab"
        android:textColor="#6750A4"
        android:textSize="11sp"
        android:textStyle="bold" />

    <ImageButton
        android:id="@+id/widget_shuffle"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_alignParentEnd="true"
        android:layout_alignParentTop="true"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:src="@android:drawable/ic_menu_rotate"
        android:tint="#6750A4"
        android:padding="6dp"
        android:scaleType="fitCenter"
        android:contentDescription="Shuffle" />

    <TextView
        android:id="@+id/widget_word"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/widget_title"
        android:layout_marginTop="4dp"
        android:text="Word"
        android:textColor="#1D1B20"
        android:textSize="18sp"
        android:textStyle="bold"
        android:maxLines="1"
        android:ellipsize="end" />

    <TextView
        android:id="@+id/widget_pos"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/widget_word"
        android:layout_marginTop="2dp"
        android:background="#EADDFF"
        android:paddingHorizontal="6dp"
        android:paddingVertical="1dp"
        android:text="pos"
        android:textColor="#21005D"
        android:textSize="10sp" />

    <TextView
        android:id="@+id/widget_translation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/widget_pos"
        android:layout_marginTop="4dp"
        android:text="Translation"
        android:textColor="#49454F"
        android:textSize="15sp"
        android:maxLines="2"
        android:ellipsize="end" />

</RelativeLayout>
